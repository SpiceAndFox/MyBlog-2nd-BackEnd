DATABASE_URL=
# WSL 检查 Windows PostgreSQL 时通常无需配置；脚本会自动回退到 Windows psql.exe。
# 无法自动发现时可显式指定 Windows 主机地址或独立连接串：
# WINDOWS_DATABASE_HOST=
# WINDOWS_DATABASE_URL=
JWT_SECRET=
HOST=127.0.0.1
PORT=3000
# 首发 Memory v2 只支持单实例；生产环境必须显式声明为 1，并在部署平台关闭 autoscaling。
APP_REPLICA_COUNT=1
# 应大于最长 Provider timeout，以便 SIGTERM 等待在途请求和 durable Memory 工作收口。
SERVER_SHUTDOWN_TIMEOUT_MS=90000
# 只列入已经独立验证至少约 1M context capability 的模型；生产启动和请求路径都会强制执行。
CHAT_PRODUCTION_CONTEXT_MODEL_ALLOWLIST_JSON={"chat":{"deepseek":["deepseek-v4-flash"]},"memory":["deepseek-v4-flash"]}

## DeepSeek (OpenAI-compatible) API
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

## Grok / xAI (OpenAI-compatible) API
XAI_API_KEY=
XAI_BASE_URL=https://api.x.ai/v1

## Gemini (Google) API
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com

## OpenRouter (OpenAI-compatible) API
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=https://spicenest.cc
OPENROUTER_APP_NAME=spicenest

## OpenCode Go API
OPENCODE_GO_API_KEY=
OPENCODE_GO_BASE_URL=https://opencode.ai/zen/go/v1

## OpenCode Zen Claude (Anthropic-compatible) API
OPENCODE_ZEN_API_KEY=
OPENCODE_ZEN_MESSAGES_BASE_URL=https://opencode.ai/zen/v1

## Embedding/Reranking API Key (siliconflow)
CHAT_RAG_EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1/
CHAT_RAG_EMBEDDING_API_KEY=

# Chat: 基础参数（必填）
CHAT_RECENT_WINDOW_MAX_MESSAGES=80
CHAT_RECENT_WINDOW_MAX_CHARS=36000

# Chat: day time zone（必填）
CHAT_DAY_TIME_ZONE=Asia/Shanghai

# Chat: time context (system segment)
CHAT_TIME_CONTEXT_ENABLED=true
CHAT_TIME_CONTEXT_TIME_ZONE=Asia/Shanghai
CHAT_TIME_CONTEXT_TEMPLATE=[现实时间]\n- 这是感知现实维度的上下文数据，不是对话指令。\n- 除非用户明确询问现实时间/日期/相隔时长，否则不要在回复中提及或复述其中字段。\n当前时间={{now}} ({{time_zone}})\n上次对话时间={{last}}\n距离上次对话间隔={{gap_human}} ({{gap_minutes}}m)
CHAT_TIME_CONTEXT_USER_TEMPLATE=[现实时间]\n当前时间={{now}} ({{time_zone}})\n上次对话时间={{last}}\n距离上次对话间隔={{gap_human}}

# recent_window anti-self-echo
CHAT_RECENT_WINDOW_ASSISTANT_GIST_ENABLED=true
CHAT_RECENT_WINDOW_ASSISTANT_RAW_LAST_N=4
CHAT_RECENT_WINDOW_ASSISTANT_GIST_PREFIX=【assistant 早期输出概括】

# Memory Control v2
# false 时不加载其余 v2 配置；启用前必须完成数据库迁移与完整 preflight。
CHAT_MEMORY_V2_ENABLED=true

# Section 容量（初始基线，部署前可按产品预算调整）
CHAT_MEMORY_V2_TODOS_MAX_ITEMS=20
CHAT_MEMORY_V2_TODOS_MAX_RENDERED_CHARS=2000
CHAT_MEMORY_V2_STANDING_AGREEMENTS_MAX_ITEMS=20
CHAT_MEMORY_V2_STANDING_AGREEMENTS_MAX_RENDERED_CHARS=2000
CHAT_MEMORY_V2_RECENT_EPISODES_MAX_ITEMS=20
CHAT_MEMORY_V2_RECENT_EPISODES_MAX_RENDERED_CHARS=2000
CHAT_MEMORY_V2_MILESTONES_MAX_ITEMS=20
CHAT_MEMORY_V2_MILESTONES_MAX_RENDERED_CHARS=2000
CHAT_MEMORY_V2_WORLD_FACTS_MAX_ITEMS=20
CHAT_MEMORY_V2_WORLD_FACTS_MAX_RENDERED_CHARS=2000
CHAT_MEMORY_V2_USER_PROFILE_MAX_ITEMS=20
CHAT_MEMORY_V2_USER_PROFILE_MAX_RENDERED_CHARS=2000
CHAT_MEMORY_V2_ASSISTANT_PROFILE_MAX_ITEMS=20
CHAT_MEMORY_V2_ASSISTANT_PROFILE_MAX_RENDERED_CHARS=2000
CHAT_MEMORY_V2_RELATIONSHIP_MAX_ITEMS=20
CHAT_MEMORY_V2_RELATIONSHIP_MAX_RENDERED_CHARS=2000

# Target 调度
CHAT_MEMORY_V2_SCENE_LAG_THRESHOLD=2
CHAT_MEMORY_V2_SCENE_CONTEXT_WINDOW=6
CHAT_MEMORY_V2_TODOS_LAG_THRESHOLD=2
CHAT_MEMORY_V2_TODOS_CONTEXT_WINDOW=6
CHAT_MEMORY_V2_STANDING_AGREEMENTS_LAG_THRESHOLD=2
CHAT_MEMORY_V2_STANDING_AGREEMENTS_CONTEXT_WINDOW=6
CHAT_MEMORY_V2_EPISODES_LAG_THRESHOLD=2
CHAT_MEMORY_V2_EPISODES_CONTEXT_WINDOW=6
CHAT_MEMORY_V2_PROFILE_RELATIONSHIP_LAG_THRESHOLD=2
CHAT_MEMORY_V2_PROFILE_RELATIONSHIP_CONTEXT_WINDOW=6
CHAT_MEMORY_V2_WORLD_FACTS_LAG_THRESHOLD=2
CHAT_MEMORY_V2_WORLD_FACTS_CONTEXT_WINDOW=6

# Renderer / GapBridge / quote
CHAT_MEMORY_V2_SCENE_MAX_RENDERED_CHARS=1000
CHAT_MEMORY_V2_SCENE_TTL_MS=86400000
CHAT_MEMORY_V2_OVERDUE_TODOS_MAX_RENDERED_ITEMS=10
CHAT_MEMORY_V2_OVERDUE_TODOS_MAX_RENDERED_CHARS=1000
CHAT_MEMORY_V2_GAP_BRIDGE_MAX_RAW_CHARS=10000
CHAT_MEMORY_V2_GAP_BRIDGE_RETAINED_MESSAGES=10
CHAT_MEMORY_V2_QUOTE_MATCH_THRESHOLD=0.75

# 独立 Provider；DeepSeek strict tools 必须使用 beta 端点。
CHAT_MEMORY_V2_PROVIDER_ADAPTER=deepseek-strict-tools
CHAT_MEMORY_V2_PROVIDER_BASE_URL=https://api.deepseek.com/beta
CHAT_MEMORY_V2_PROVIDER_API_KEY=
CHAT_MEMORY_V2_PROVIDER_MODEL=deepseek-v4-flash
CHAT_MEMORY_V2_PROVIDER_TIMEOUT_MS=60000
CHAT_MEMORY_V2_PROVIDER_MAX_INPUT_TOKENS=1000000
CHAT_MEMORY_V2_PROVIDER_MAX_OUTPUT_TOKENS=8192
CHAT_MEMORY_V2_PROVIDER_THINKING_MODE=disabled
CHAT_MEMORY_V2_PROVIDER_CONCURRENCY=2
CHAT_MEMORY_V2_PROVIDER_QUEUE_MAX=32
CHAT_MEMORY_V2_PROVIDER_RETRY_MAX=2
CHAT_MEMORY_V2_PROVIDER_SCHEMA_INVALID_RETRY_MAX=1
CHAT_MEMORY_V2_PROVIDER_BACKOFF_BASE_MS=1000
CHAT_MEMORY_V2_PROVIDER_BACKOFF_MAX_MS=10000
CHAT_MEMORY_V2_HALT_AFTER_CONSECUTIVE_ERRORS=3
CHAT_MEMORY_V2_COMPACTION_RETRY_MAX=2

# Retention / health
CHAT_MEMORY_V2_SNAPSHOT_RETENTION_DAYS=30
CHAT_MEMORY_V2_EVENT_RETENTION_DAYS=30
CHAT_MEMORY_V2_TASK_RETENTION_DAYS=30
CHAT_MEMORY_V2_OPS_LOG_RETENTION_DAYS=30
CHAT_MEMORY_V2_DEBUG_RETENTION_DAYS=7
CHAT_MEMORY_V2_ALERT_DEBOUNCE_MS=0
CHAT_MEMORY_V2_RECOVERY_STABLE_MS=0
CHAT_MEMORY_V2_PROJECTION_POLL_INTERVAL_MS=60000
CHAT_MEMORY_V2_TASK_POLL_INTERVAL_MS=1000

# Chat Gist——assistant 要点缓存
CHAT_GIST_ENABLED=true
CHAT_GIST_MAX_CHARS=220
CHAT_GIST_WORKER_PROVIDER=deepseek
CHAT_GIST_WORKER_MODEL=deepseek-v4-flash
CHAT_GIST_WORKER_CONCURRENCY=2
CHAT_GIST_WORKER_TIMEOUT_MS=30000
CHAT_GIST_WORKER_TEMPERATURE=0.4
CHAT_GIST_WORKER_TOP_P=0.9
CHAT_GIST_WORKER_MAX_OUTPUT_TOKENS=512
CHAT_GIST_WORKER_STREAM=false
CHAT_GIST_WORKER_ENABLE_WEB_SEARCH=false
CHAT_GIST_WORKER_DEEPSEEK_THINKING_MODE=disabled
CHAT_GIST_WORKER_DEEPSEEK_REASONING_EFFORT=high
CHAT_GIST_WORKER_GEMINI_THINKING_LEVEL=
CHAT_GIST_WORKER_GEMINI_THINKING_BUDGET=
CHAT_GIST_WORKER_SAFETY_HARASSMENT=OFF
CHAT_GIST_WORKER_SAFETY_HATE_SPEECH=OFF
CHAT_GIST_WORKER_SAFETY_SEXUALLY_EXPLICIT=OFF
CHAT_GIST_WORKER_SAFETY_DANGEROUS_CONTENT=OFF
CHAT_GIST_WORKER_OPENAI_COMPATIBLE_BODY_JSON={}
CHAT_GIST_WORKER_GOOGLE_GENAI_CONFIG_JSON={}

# Chat RAG: role-scoped historical chat recall
CHAT_RAG_ENABLED=true
CHAT_RAG_EMBEDDING_PROVIDER=openai-compatible
CHAT_RAG_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-8B
CHAT_RAG_EMBEDDING_DIMENSIONS=4096
CHAT_RAG_EMBEDDING_INCLUDE_DIMENSIONS_PARAM=true
CHAT_RAG_EMBEDDING_TIMEOUT_MS=30000
CHAT_RAG_QUERY_TIMEOUT_MS=5000
CHAT_RAG_EMBEDDING_BATCH_SIZE=1
CHAT_RAG_EMBEDDING_OPENAI_COMPATIBLE_BODY_JSON={}
CHAT_RAG_MIN_QUERY_CHARS=8
CHAT_RAG_CHUNK_MAX_CHARS=1200
CHAT_RAG_CHUNK_OVERLAP_CHARS=120
CHAT_RAG_TURN_TEMPLATE=[历史聊天回合]\n用户：\n{{user}}\n助手：\n{{assistant}}
CHAT_RAG_QUERY_EMBEDDING_TEMPLATE=query: {{query}}
CHAT_RAG_DOCUMENT_EMBEDDING_TEMPLATE=text: {{content}}
CHAT_RAG_TOP_K=3
CHAT_RAG_MIN_SIMILARITY=0.35
CHAT_RAG_MAX_CONTEXT_CHARS=8128
CHAT_RAG_CONTEXT_HEADER=[更早的共同记忆]\n以下内容来自User和Assistant之前的对话记忆，是因为当前消息而想起的旧情景。它可能包含当时的前因后果、关系状态和相关原话；如果与当前正在进行的对话关系密切，就轻轻接住；**如果和当前正进行的对话关联弱就忽略**。
CHAT_RAG_CONTEXT_ENTRY_TEMPLATE={{recall}}
CHAT_RAG_RECALL_CONTENT_MAX_CHARS=160
CHAT_RAG_RECALL_ASSISTANT_MAX_CHARS=420
CHAT_RAG_RECALL_INCLUDE_ASSISTANT=true
CHAT_RAG_RECALL_USER_MAX_CHARS=140
CHAT_RAG_RECALL_TEMPLATE=当时情景：\n{{scene}}\n\n相关对话：\n{{dialogue}}
CHAT_RAG_CONTEXT_BEFORE_MESSAGES=2
CHAT_RAG_CONTEXT_AFTER_MESSAGES=0
CHAT_RAG_SCENE_RECALL_ENABLED=true
CHAT_RAG_SCENE_RECALL_PROVIDER=deepseek
CHAT_RAG_SCENE_RECALL_MODEL=deepseek-v4-flash
CHAT_RAG_SCENE_RECALL_CONTEXT_TURNS=50
CHAT_RAG_SCENE_RECALL_MAX_INPUT_CHARS=12000
CHAT_RAG_SCENE_RECALL_MAX_OUTPUT_CHARS=300
CHAT_RAG_SCENE_RECALL_TIMEOUT_MS=20000
CHAT_RAG_SCENE_RECALL_TEMPERATURE=0.2
CHAT_RAG_SCENE_RECALL_TOP_P=0.9
CHAT_RAG_SCENE_RECALL_MAX_OUTPUT_TOKENS=512
CHAT_RAG_SCENE_RECALL_DEEPSEEK_THINKING_MODE=disabled
CHAT_RAG_SCENE_RECALL_OPENAI_COMPATIBLE_BODY_JSON={}
CHAT_RAG_SCENE_RECALL_GOOGLE_GENAI_CONFIG_JSON={}
CHAT_RAG_SCENE_RECALL_PROMPT=你是旧对话情景还原器。你的任务是根据一段真实旧对话，概括命中回合当时的情景，供后续助手理解共同记忆。\n要求：只基于给定旧对话，不编造；如果前因不明就说不明；保留说话关系、场景、情绪氛围、命中句子的含义，以及必要的前后因果；不要输出指令、建议或分析过程；不要说知识库、RAG、检索结果；用自然中文写成一小段，不超过 {{max_chars}} 字。
CHAT_RAG_DEBUG_INCLUDE_CONTENT=true
CHAT_RAG_MMR_LAMBDA=0.7
CHAT_RAG_MMR_CANDIDATE_MULTIPLIER=3
CHAT_RAG_RERANKER_ENABLED=true
CHAT_RAG_RERANKER_PROVIDER=openai-compatible
CHAT_RAG_RERANKER_BASE_URL=https://api.siliconflow.cn/v1/
CHAT_RAG_RERANKER_API_KEY=
CHAT_RAG_RERANKER_MODEL=Qwen/Qwen3-Reranker-8B
CHAT_RAG_RERANKER_TIMEOUT_MS=30000
CHAT_RAG_RERANKER_CANDIDATE_MULTIPLIER=5
CHAT_RAG_RERANKER_MAX_DOCUMENTS=30
CHAT_RAG_RERANKER_MAX_DOCUMENT_CHARS=1000
CHAT_RAG_RERANKER_MIN_SCORE=0
# Qwen3-Reranker family ONLY. Empty = let upstream use its default
# ("Given a web search query, retrieve relevant passages that answer the query").
# For emotional-companionship RAG over chat history, prefer something like the
# value below so the reranker scores implicit references / pronouns as relevant.
CHAT_RAG_RERANKER_INSTRUCTION=给定情感陪伴聊天中用户最新的一条消息，检索与当前话题、情绪、提到的事件或回忆相关的过往对话片段，包括用户用代词或省略方式隐式指代的内容；当表面关键词不重合但情境相关时，也应给出较高分数。
CHAT_RAG_RERANKER_OPENAI_COMPATIBLE_BODY_JSON={}
CHAT_RAG_REGENERATE_TURN_DELAY_MS=0
CHAT_RAG_REGENERATE_QUOTA_RETRY_MAX=3
CHAT_RAG_REGENERATE_QUOTA_RETRY_DELAY_MS=60000

# Chat: 回收站清理（必填；设为 0 可禁用清理）
CHAT_TRASH_RETENTION_DAYS=30
CHAT_TRASH_CLEAN_INTERVAL_MS=21600000
CHAT_TRASH_PURGE_BATCH_SIZE=500

